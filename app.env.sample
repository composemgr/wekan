# Wekan - app.env.sample
# Copy to app.env and adjust values before starting

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=$HOSTNAME

# Database credentials
DB_CREATE_DATABASE_NAME=wekan
DB_USER_NAME=wekan
DB_USER_PASS=changeme_db_password
DB_ADMIN_NAME=root
DB_ADMIN_PASS=changeme_admin_password

# Email / SMTP settings
EMAIL_SERVER_HOST=172.17.0.1
EMAIL_SERVER_PORT=587
EMAIL_SERVER_MAIL_FROM=noreply@example.com
